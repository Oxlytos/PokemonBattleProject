<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PokemonBattle.TeamBuilderPage">

    <Grid Margin="25" ColumnSpacing="10" >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Button
          Grid.Row="1"
          Grid.Column="0"
          WidthRequest="150"
          VerticalOptions="Center"
          HorizontalOptions="Center"
          Text="GetPokemons"
            Command="{Binding GetPokemonCommand}"
          />
        <Button 
          Grid.Row="0" 
          Grid.Column="0" 
          Text="BattleButton" 
          Clicked="OnClickBattleButton"   
          WidthRequest="150"
          VerticalOptions="Center"
          HorizontalOptions="Center"/>
        <CollectionView 
           Grid.Row="2"
           Grid.Column="0"
           VerticalOptions="Start"
          WidthRequest="150"
          HorizontalOptions="Center"
          ItemsSource="{Binding AllPokemon}"
          x:Name="MyCollectionView"
          SelectionMode="Single"
          SelectedItem="{Binding SelectedPokemonModel, Mode=TwoWay}"
                              >
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Padding="5" >
                        <Label Text="{Binding Name}" FontSize="18"/>
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <CollectionView 
        Grid.Row="1"
        Grid.Column="3"
        VerticalOptions="Start"
          MinimumHeightRequest="150"
       HorizontalOptions="Center"
       ItemsSource="{Binding TeamPokemon}"
       x:Name="TeamCollectionView"
          SelectedItem="{Binding SelectedPokemonModel,Mode=TwoWay}"
       SelectionMode="Single"
                           >
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"></LinearItemsLayout>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Padding="5" >
                        <Label Text="{Binding Name}" FontSize="18"/>
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout
      Grid.Row="1"
      Grid.Column="2"
      HorizontalOptions="Center"
      VerticalOptions="Center"
      Spacing="10">
            <Label
          x:Name="CurrentChoosenPokemon"
              HorizontalTextAlignment="Center"
              WidthRequest="100"
          Text="{Binding PokemonName}"
              HorizontalOptions="Center"/>
            <Image
            x:Name="PokemonImage"
              VerticalOptions="Center"
          WidthRequest="150"
          HeightRequest="150"
          Aspect="AspectFit"
           Source="{Binding PokemonImage}" />
        </VerticalStackLayout>
        <Button        
          WidthRequest="150"
         HeightRequest="50"
         Grid.Row="2"
         Grid.Column="1"
          Command="{Binding AddToTeamCommand}"
          Text="Add to team"
          TextColor="Black"
          BackgroundColor="LightGreen">

        </Button>
    </Grid>
</ContentPage>