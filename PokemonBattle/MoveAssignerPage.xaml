<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PokemonBattle.MoveAssignerPage"
             Title="MoveAssignerPage">
    <Grid Margin="50" ColumnSpacing="50" >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <!-- Horizontal grid lines -->
        <BoxView Grid.Row="0" Grid.ColumnSpan="5" HeightRequest="1" BackgroundColor="Red"/>
        <BoxView Grid.Row="1" Grid.ColumnSpan="5" HeightRequest="1" BackgroundColor="Red"/>
        <BoxView Grid.Row="2" Grid.ColumnSpan="5" HeightRequest="1" BackgroundColor="Red"/>
        <BoxView Grid.Row="3" Grid.ColumnSpan="5" HeightRequest="1" BackgroundColor="Red"/>
        <BoxView Grid.Row="4" Grid.ColumnSpan="5" HeightRequest="1" BackgroundColor="Red"/>
        <!-- Extra bottom line -->
        <BoxView Grid.Row="4" Grid.ColumnSpan="5" HeightRequest="1" BackgroundColor="Red" VerticalOptions="End"/>

        <!-- Vertical grid lines -->
        <BoxView Grid.Column="0" Grid.RowSpan="5" WidthRequest="1" BackgroundColor="Blue"/>
        <BoxView Grid.Column="1" Grid.RowSpan="5" WidthRequest="1" BackgroundColor="Blue"/>
        <BoxView Grid.Column="2" Grid.RowSpan="5" WidthRequest="1" BackgroundColor="Blue"/>
        <BoxView Grid.Column="3" Grid.RowSpan="5" WidthRequest="1" BackgroundColor="Blue"/>
        <BoxView Grid.Column="4" Grid.RowSpan="5" WidthRequest="1" BackgroundColor="Blue"/>
        <!-- Extra right line -->
        <BoxView Grid.Column="4" Grid.RowSpan="5" WidthRequest="1" BackgroundColor="Blue" HorizontalOptions="End"/>
        <Label
            Grid.Row="0"
            Grid.Column="0"
            Text="Move page"/>
        <HorizontalStackLayout
      Grid.Row="0"
      Grid.Column="1">
            <Button 
         Text="Main Menu"
         WidthRequest="150"
         VerticalOptions="Center"
         HorizontalOptions="Center"
                Clicked="GoToMainMenuButtonClicked"
         />
            <Button 
       Text="Go Back" 
                Clicked="GoBackButtonClicked"
       WidthRequest="150"
       VerticalOptions="Center"
       HorizontalOptions="Center"/>
            <Button
                Text="Get Moves"
       WidthRequest="150"
       VerticalOptions="Center"
       HorizontalOptions="Center"
       Command="{Binding GetMovesCommand}"/>
            
        </HorizontalStackLayout>
        <VerticalStackLayout
        Grid.Row="1"
        Grid.Column="1"
        HorizontalOptions="Center"
        VerticalOptions="Center"
        Spacing="10">
            <Label
        x:Name="CurrentChoosenPokemon"
            HorizontalTextAlignment="Center"
            WidthRequest="100"
        Text="{Binding PokemonName}"
            HorizontalOptions="Center"/>
            <Image
          x:Name="PokemonImage"
            VerticalOptions="Center"
        WidthRequest="200"
        HeightRequest="200"
        Aspect="AspectFit"
         Source="{Binding PokemonImage}" />
        </VerticalStackLayout>
        <Label
            Text="Yellow"
            Grid.Row="1"
            Grid.Column="2"/>
        <CollectionView 
          Grid.Row="1"
          Grid.Column="3"
            BackgroundColor="DimGray"
          VerticalOptions="Start"
            MinimumWidthRequest="400"
          HorizontalOptions="Center"
          ItemsSource="{Binding CurrentMoves}"
          x:Name="CurrentMoves"
          SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                        <HorizontalStackLayout
                            Spacing="25"
                            VerticalOptions="Center"
                            HorizontalOptions="Fill"
                            >
                            <Button
                                VerticalOptions="Center"
                             Text="Remove"
                                TextColor="Wheat"
                                TextTransform="Uppercase"
                                Background="Crimson"
                             CornerRadius="0"
                             />
                            <Label 
                                Text="{Binding DisplayInfo}" 
                                FontSize="18"
                                VerticalTextAlignment="Center"
                                HorizontalTextAlignment="Center"
                                
                                />
                        </HorizontalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <CollectionView 
          Grid.Row="1"
          Grid.Column="2"
          VerticalOptions="Start"
         BackgroundColor="DimGray"
          WidthRequest="250"
          HorizontalOptions="Center"
          ItemsSource="{Binding AvailableMoves}"
          x:Name="MyCollectionView"
          SelectionMode="Single"
          SelectedItem="{Binding CurrentMove, Mode=TwoWay}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Padding="5" >
                        <Label Text="{Binding Move.Name}" FontSize="18" HorizontalTextAlignment="Start"/>
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Button
            Text="Add Move"
            Command="{Binding AddMoveCommand}"
             WidthRequest="150"
            HeightRequest="50"
             Grid.Row="2"
             Grid.Column="2"/>

    </Grid>

</ContentPage>