<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PokemonBattle.BattlePage"
             Title="BattlePage">
    <!--Huvud gridden-->
    <Grid Margin="25" ColumnSpacing="10" >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Label 
            Grid.Row="3"
            Grid.Column="2"
            Text="{Binding StatusMessage}"
            FontSize="28"/>
        <!-- Horizontal grid lines -->
        <BoxView Grid.Row="0" Grid.ColumnSpan="5" HeightRequest="1" BackgroundColor="Red"/>
        <BoxView Grid.Row="1" Grid.ColumnSpan="5" HeightRequest="1" BackgroundColor="Red"/>
        <BoxView Grid.Row="2" Grid.ColumnSpan="5" HeightRequest="1" BackgroundColor="Red"/>
        <BoxView Grid.Row="3" Grid.ColumnSpan="5" HeightRequest="1" BackgroundColor="Red"/>
        <BoxView Grid.Row="4" Grid.ColumnSpan="5" HeightRequest="1" BackgroundColor="Red"/>
        <!-- Extra bottom line -->
        <BoxView Grid.Row="4" Grid.ColumnSpan="5" HeightRequest="1" BackgroundColor="Red" VerticalOptions="End"/>

        <!-- Vertical grid lines -->
        <BoxView Grid.Column="0" Grid.RowSpan="5" WidthRequest="1" BackgroundColor="Blue"/>
        <BoxView Grid.Column="1" Grid.RowSpan="5" WidthRequest="1" BackgroundColor="Blue"/>
        <BoxView Grid.Column="2" Grid.RowSpan="5" WidthRequest="1" BackgroundColor="Blue"/>
        <BoxView Grid.Column="3" Grid.RowSpan="5" WidthRequest="1" BackgroundColor="Blue"/>
        <BoxView Grid.Column="4" Grid.RowSpan="5" WidthRequest="1" BackgroundColor="Blue"/>
        <!-- Extra right line -->
        <BoxView Grid.Column="4" Grid.RowSpan="5" WidthRequest="1" BackgroundColor="Blue" HorizontalOptions="End"/>




        <Grid
               Grid.Row="1"
               Grid.Column="3"
               Grid.ColumnSpan="3"
                Grid.RowSpan="1"
               MinimumWidthRequest="500">
            <Border
                Padding="10"
                BackgroundColor="AliceBlue"
                WidthRequest="300"
                MinimumHeightRequest="100"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Margin="0,-300,0,0"
                >
                <VerticalStackLayout>
                   
                    <Label
                        Text="{Binding CurrentAiPokemon.DisplayHealth}"
                        TextTransform="Uppercase"
                        TextColor="Black"
                        />
                    <Label
                        Text="{Binding CurrentAiPokemon.NicknameOrName}"
                        TextColor="Black"/>
                    <Label
                        Text="{Binding CurrentAiPokemon.PartyPokemon.Level}"
                        TextColor="Black"/>
                </VerticalStackLayout>
            </Border>
            <Image
                    VerticalOptions="Center"
                WidthRequest="300"
                HeightRequest="300"
                Aspect="AspectFit"
                       Margin="0, 10, 0, 0"
                Source="{Binding OpponentPokemon}"
                />
           
        </Grid>

        <!-- PlayerPokeon-->
        <Grid
        Grid.Row="4"
        Grid.Column="0"
        Grid.ColumnSpan="6"
        VerticalOptions="FillAndExpand"
        MinimumWidthRequest="500"
            >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1*"/>
                
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/> <!-- -->
                <RowDefinition Height="Auto"/> <!--Pokemon sprite here-->
            </Grid.RowDefinitions>
            <Image
             Grid.Column="0"
             Grid.Row="0"
             TranslationY="100"
              WidthRequest="400"
              HeightRequest="400"
              VerticalOptions="End"
              HorizontalOptions="Center"
              Source="{Binding PlayerPokemonImage}"
             />


            <Grid Grid.Column="0" Grid.Row="1" HeightRequest="260">
                <CollectionView
                    ItemsSource="{Binding CurrentPlayerPokemonMoves}"
                    ItemSizingStrategy="MeasureAllItems"
                        VerticalOptions="Start"
                        HorizontalOptions="Fill"
                        >
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                            <Grid BackgroundColor="Red" Margin="2">
                        <!--Irreterand sätt att gå upp i hiearkin från knapp till viewmodel/binding context för att nå command-->
                        <Button
                        Text="{Binding DisplayInfo}"
                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ClickMoveCommand}"                            
                        CommandParameter="{Binding Name}"
                        TextTransform="Uppercase"
                        BackgroundColor="Beige"
                        CornerRadius="0"
                        BorderColor="Orange"
                        HeightRequest="120"
                        VerticalOptions="FillAndExpand"
                        HorizontalOptions="FillAndExpand"
                        />
                            </Grid>
                        </DataTemplate>
                </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            <CollectionView
                Grid.Column="1"
                x:Name="PlayerTeamCollection"
                Grid.Row="1"
                ItemsSource="{Binding DisplayPlayerParty}"
                VerticalOptions="Center"
                     TranslationY="-140"
                HorizontalOptions="Center">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Image
                       Source="{Binding SpriteImage}"
                       HeightRequest="96"
                       WidthRequest="96">
                            <Image.GestureRecognizers>
                            <TapGestureRecognizer
    NumberOfTapsRequired="2"
    Command="{Binding Source={x:Reference PlayerTeamCollection}, Path=BindingContext.SwitchPokemonCommand}"
    CommandParameter="{Binding .}"
    >
                            </TapGestureRecognizer>
                            </Image.GestureRecognizers>
                        </Image>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Border
                Stroke="AliceBlue"
                Grid.Column="1"
                Grid.Row="2"
                  Padding="15" 
                BackgroundColor="Bisque"
                HorizontalOptions="Fill"
                VerticalOptions="Center">
                <VerticalStackLayout 
                    Spacing="10"
                    HorizontalOptions="Fill"
                    >
                   
                    <Label 
                        Text="{Binding CurrentPlayerPartyPokemon.DisplayHealth}"
                        TextTransform="Uppercase"
                        TextColor="Black"
                        />
                    <Label 
                     Text="{Binding CurrentPlayerPartyPokemon.NicknameOrName}"
                     TextColor="Black"
                     /> 
                    <Label 
                        
                        Text="{Binding CurrentPlayerPartyPokemon.PartyPokemon.Level}"
                        TextTransform="Uppercase"
                        TextColor="Black"/>
                    <Button
                        CornerRadius="0"
                        Text="Party"/>
                    <Button
                        CornerRadius="0"
                        Text="Forfeit"></Button>
                </VerticalStackLayout>
            </Border>
            
        </Grid>
    </Grid>
</ContentPage>